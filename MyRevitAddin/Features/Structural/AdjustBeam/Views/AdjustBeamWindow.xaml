<Window x:Class="MyRevitAddin.Features.Structural.AdjustBeam.Views.AdjustBeamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adjust structural beam"
        Height="360"
        Width="480"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="150" />
        </Grid.ColumnDefinitions>

        <!-- Row 0 -->
        <TextBlock Text="Beam -> Wall clearance (mm)"
                   VerticalAlignment="Center"
                   Margin="0,5" />
        <TextBox Grid.Column="1"
                 Text="{Binding Config.BeamToWallClearance}"
                 Margin="0,5"
                 VerticalContentAlignment="Center"
                 Height="24" />

        <!-- Row 1 -->
        <TextBlock Grid.Row="1"
                   Text="Beam -> Pillar clearance (mm)"
                   VerticalAlignment="Center"
                   Margin="0,5" />
        <TextBox Grid.Row="1"
                 Grid.Column="1"
                 Text="{Binding Config.BeamToPillarClearance}"
                 Margin="0,5"
                 VerticalContentAlignment="Center"
                 Height="24" />

        <!-- Row 2 -->
        <TextBlock Grid.Row="2"
                   Text="Beam -> Beam inline gap (mm)"
                   VerticalAlignment="Center"
                   Margin="0,5" />
        <TextBox Grid.Row="2"
                 Grid.Column="1"
                 Text="{Binding Config.BeamToBeamInlineGap}"
                 Margin="0,5"
                 VerticalContentAlignment="Center"
                 Height="24" />

        <!-- Row 3 -->
        <TextBlock Grid.Row="3"
                   Text="Beam -> Beam perpendicular gap (mm)"
                   VerticalAlignment="Center"
                   Margin="0,5" />
        <TextBox Grid.Row="3"
                 Grid.Column="1"
                 Text="{Binding Config.BeamToBeamPerpendicularGap}"
                 Margin="0,5"
                 VerticalContentAlignment="Center"
                 Height="24" />

        <!-- Row 4 -->
        <TextBlock Grid.Row="4"
                   Text="Beam corner at pillar"
                   VerticalAlignment="Center"
                   Margin="0,5" />
        <ComboBox Grid.Row="4"
                  Grid.Column="1"
                  ItemsSource="{Binding CornerOptions}"
                  SelectedItem="{Binding Config.BeamCornerAtPillar}"
                  Margin="0,5"
                  Height="24" />

        <!-- Row 5 & 6 Checkboxes (Full width) -->
        <Border Grid.Row="5"
                Grid.ColumnSpan="2"
                Grid.RowSpan="2"
                Background="#7b9eab"
                Margin="0,10,0,0">
            <StackPanel Margin="10">
                <CheckBox Content="Corner / T-shape at pillar: extend to beam body"
                          IsChecked="{Binding Config.CornerTShapeAtPillarExtendToBeamBody}"
                          Margin="0,0,0,10" />
                <CheckBox Content="Corner at wall: extend to beam body"
                          IsChecked="{Binding Config.CornerAtWallExtendToBeamBody}" />
            </StackPanel>
        </Border>

        <!-- Button -->
        <Button Grid.Row="8"
                Grid.Column="1"
                Content="Adjust"
                Command="{Binding AdjustCommand}"
                Width="80"
                Height="30"
                HorizontalAlignment="Right"
                Margin="0,15,0,0" />
    </Grid>
</Window>
