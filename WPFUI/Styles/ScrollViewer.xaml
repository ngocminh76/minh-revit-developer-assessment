<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/WPFUI;component/Styles/Brushes.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ============================================ -->
    <!-- GLOBAL SCROLLBAR DIMENSIONS                  -->
    <!-- ============================================ -->
    <system:Double x:Key="SlimScrollBar.Width">12</system:Double>
    <system:Double x:Key="SlimScrollBar.Height">12</system:Double>
    <system:Double x:Key="SlimScrollBar.ThumbWidth">8</system:Double>
    <system:Double x:Key="SlimScrollBar.ThumbHeight">8</system:Double>

    <!-- Slim ScrollBar Colors -->
    <SolidColorBrush x:Key="SlimScrollBar.Static.Background" Color="Transparent"/>
    <SolidColorBrush x:Key="SlimScrollBar.Static.Border" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SlimScrollBar.Static.Thumb" Color="#B3C7DC"/>        <!-- Lighter shade of #004085 -->
    <SolidColorBrush x:Key="SlimScrollBar.MouseOver.Thumb" Color="#0056b3"/>    <!-- PrimaryHoverColor -->
    <SolidColorBrush x:Key="SlimScrollBar.Pressed.Thumb" Color="#004085"/>      <!-- PrimaryPressedColor -->

    <!-- Slim Vertical ScrollBar Thumb -->
    <Style x:Key="SlimScrollBarThumbVertical" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="IsTabStop" Value="false"/>
        <Setter Property="Width" Value="{StaticResource SlimScrollBar.ThumbWidth}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="thumbBorder"
                            Background="{StaticResource SlimScrollBar.Static.Thumb}"
                            CornerRadius="4"
                            Margin="2,0,2,0"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="thumbBorder" Property="Background" 
                                    Value="{StaticResource SlimScrollBar.MouseOver.Thumb}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="true">
                            <Setter TargetName="thumbBorder" Property="Background" 
                                    Value="{StaticResource SlimScrollBar.Pressed.Thumb}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Slim Horizontal ScrollBar Thumb -->
    <Style x:Key="SlimScrollBarThumbHorizontal" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="IsTabStop" Value="false"/>
        <Setter Property="Height" Value="{StaticResource SlimScrollBar.ThumbHeight}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="thumbBorder"
                            Background="{StaticResource SlimScrollBar.Static.Thumb}"
                            CornerRadius="4"
                            Margin="0,2,0,2"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="thumbBorder" Property="Background" 
                                    Value="{StaticResource SlimScrollBar.MouseOver.Thumb}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="true">
                            <Setter TargetName="thumbBorder" Property="Background" 
                                    Value="{StaticResource SlimScrollBar.Pressed.Thumb}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Transparent RepeatButton (for page up/down areas) -->
    <Style x:Key="SlimScrollBarPageButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Focusable" Value="false"/>
        <Setter Property="IsTabStop" Value="false"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Rectangle Fill="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Slim Vertical ScrollBar Template -->
    <ControlTemplate x:Key="SlimVerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid x:Name="Bg" Background="{TemplateBinding Background}">
            <Track x:Name="PART_Track" IsDirectionReversed="true">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                  Style="{StaticResource SlimScrollBarPageButton}"/>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                  Style="{StaticResource SlimScrollBarPageButton}"/>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource SlimScrollBarThumbVertical}"/>
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <!-- Slim Horizontal ScrollBar Template -->
    <ControlTemplate x:Key="SlimHorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid x:Name="Bg" Background="{TemplateBinding Background}">
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}"
                                  Style="{StaticResource SlimScrollBarPageButton}"/>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}"
                                  Style="{StaticResource SlimScrollBarPageButton}"/>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource SlimScrollBarThumbHorizontal}"/>
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <!-- Slim Vertical ScrollBar Style -->
    <Style x:Key="SlimVerticalScrollBar" TargetType="{x:Type ScrollBar}">
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="{StaticResource SlimScrollBar.Width}"/>
        <Setter Property="MinWidth" Value="{StaticResource SlimScrollBar.Width}"/>
        <Setter Property="Template" Value="{StaticResource SlimVerticalScrollBarTemplate}"/>
    </Style>

    <!-- Slim Horizontal ScrollBar Style -->
    <Style x:Key="SlimHorizontalScrollBar" TargetType="{x:Type ScrollBar}">
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="{StaticResource SlimScrollBar.Height}"/>
        <Setter Property="MinHeight" Value="{StaticResource SlimScrollBar.Height}"/>
        <Setter Property="Template" Value="{StaticResource SlimHorizontalScrollBarTemplate}"/>
    </Style>

    <!-- Implicit ScrollBar Style (Ensures standalone scrollbars adopt these templates) -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
        <Setter Property="Background" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="{StaticResource SlimScrollBar.Width}"/>
                <Setter Property="MinWidth" Value="{StaticResource SlimScrollBar.Width}"/>
                <Setter Property="Template" Value="{StaticResource SlimVerticalScrollBarTemplate}"/>
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="{StaticResource SlimScrollBar.Height}"/>
                <Setter Property="MinHeight" Value="{StaticResource SlimScrollBar.Height}"/>
                <Setter Property="Template" Value="{StaticResource SlimHorizontalScrollBarTemplate}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Slim ScrollViewer Style for general use (Border, etc.) -->
    <Style x:Key="SlimScrollViewerStyle" TargetType="{x:Type ScrollViewer}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollViewer}">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Content -->
                        <ScrollContentPresenter Grid.Row="0" Grid.Column="0"
                                                x:Name="PART_ScrollContentPresenter"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                                Content="{TemplateBinding Content}"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"/>

                        <!-- Vertical ScrollBar -->
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Row="0" Grid.Column="1"
                                   Style="{StaticResource SlimVerticalScrollBar}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   Minimum="0"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                        <!-- Horizontal ScrollBar -->
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Row="1" Grid.Column="0"
                                   Style="{StaticResource SlimHorizontalScrollBar}"
                                   Orientation="Horizontal"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   Minimum="0"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                   Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Implicit ScrollViewer Style (Applies to all ScrollViewers, DataGrids, ListViews, etc.) -->
    <Style TargetType="{x:Type ScrollViewer}" BasedOn="{StaticResource SlimScrollViewerStyle}"/>

</ResourceDictionary>
